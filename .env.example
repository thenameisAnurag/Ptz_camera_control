# ─────────────────────────────────────────────
# PTZ Camera Credentials  (copy this file → .env)
# ─────────────────────────────────────────────
CAMERA_IP=192.168.0.XX
CAMERA_USERNAME=your_username
CAMERA_PASSWORD=your_password

# ─────────────────────────────────────────────
# Optional tuning  (defaults shown)
# ─────────────────────────────────────────────
# Manual movement speed (0.0 – 1.0)
PTZ_SPEED=0.35
ZOOM_SPEED=0.3

# Auto-tracking parameters
TRACK_SPEED=0.25
DEAD_ZONE=0.10
TRACK_CLASS=39           # COCO class id (39 = bottle, 0 = person, 4 = airplane)
YOLO_CONF=0.20
STALE_FRAMES=15
YOLO_MODEL=yolov8n.pt    # path to .pt weights
